<idea-plugin>
	<id>com.aradiors.ftccompanion</id>
	<name>FTC Companion (Local Fork)</name>
	<vendor email="yoyo@example.com" url="https://github.com/yehon">yoyo (FTC Team Aradiors)</vendor>
	<description>Local fork of FTC Companion plugin for Android Studio. Originally created by the FTC Team Aradiors.</description>
	<change-notes>
		- Local fork based on original FTC Companion plugin
		- Added support for Android Studio Otter (2025.2)
	</change-notes>

	<depends>com.intellij.modules.platform</depends>
	<depends>com.intellij.modules.java</depends>

	<extensions defaultExtensionNs="com.intellij">
		<toolWindow
				id="Robot controller console"
				icon="AllIcons.Actions.InlayRenameInComments"
				anchor="right"
				factoryClass="si.vegamind.ftccompanion.extensions.toolwindow.ControllerConsoleFactory"
		/>
		<projectService
				serviceImplementation="si.vegamind.ftccompanion.extensions.settings.AppSettings"/>
		<projectConfigurable
				parentId="tools"
				instance="si.vegamind.ftccompanion.extensions.settings.AppSettingsConfigurable"
				id="si.vegamind.ftccompanion.extensions.settings.AppSettingsConfigurable"
				displayName="FTC Companion"
		/>
        <internalFileTemplate name="TeleOp"/>
        <internalFileTemplate name="Autonomous"/>
        <internalFileTemplate name="SolversAuto"/>
        <internalFileTemplate name="SolversTeleOp"/>
	</extensions>

	<actions>
		<group id="si.vegamind.ftccompanion.actions.filetree.FTCGroup" text="FTC" popup="true" icon="AllIcons.Nodes.ModuleGroup">
			<add-to-group group-id="NewGroup" anchor="last"/>

			<action
					id="si.vegamind.ftccompanion.actions.filetree.NewTeleOp"
					class="si.vegamind.ftccompanion.actions.filetree.NewTeleOp"
					text="TeleOp"
					description="Creates a new TeleOp OpMode class"
					icon="AllIcons.Nodes.Class">
			</action>

			<action
					id="si.vegamind.ftccompanion.actions.filetree.NewAutonomous"
					class="si.vegamind.ftccompanion.actions.filetree.NewAutonomous"
					text="Autonomous"
					description="Creates a new Autonomous OpMode class"
					icon="AllIcons.Nodes.Class">
			</action>

			<action
					id="si.vegamind.ftccompanion.actions.filetree.NewSolversAuto"
					class="si.vegamind.ftccompanion.actions.filetree.NewSolversAuto"
					text="SolversAuto"
					description="Creates a new SolversAuto OpMode class"
					icon="AllIcons.Nodes.Class">
			</action>

			<action
					id="si.vegamind.ftccompanion.actions.filetree.NewSolversTeleOp"
					class="si.vegamind.ftccompanion.actions.filetree.NewSolversTeleOp"
					text="SolversTeleOp"
					description="Creates a new SolversTeleOp OpMode class"
					icon="AllIcons.Nodes.Class">
			</action>
		</group>
	</actions>
</idea-plugin>